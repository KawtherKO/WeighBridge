<UserControl x:Class="WeighBridge.Views.UserControls.WeighmentHistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ────── Modern ComboBox resources ────── (added) -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="ComboBoxBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ComboBoxBorder" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="ComboBoxBorderFocus" Color="#0078D4"/>
        <!-- your brand primary -->
        <SolidColorBrush x:Key="ItemHover" Color="#F2F4F7"/>
        <SolidColorBrush x:Key="ItemSelected" Color="#E8EDF2"/>
        <SolidColorBrush x:Key="ItemText" Color="#101828"/>

        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource ComboBoxBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ComboBoxBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#101828"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <ToggleButton x:Name="ToggleButton"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"
                                                        CornerRadius="0,6,6,0">
                                                    <Path Data="M0,0 L4,4 L8,0"
                                                          Fill="#667085"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,4,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Background="{StaticResource ComboBoxBg}"
                                        BorderBrush="{StaticResource ComboBoxBorderFocus}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,2,0,0">
                                    <ScrollViewer Margin="4">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ComboBoxBorderFocus}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ComboBoxBorderFocus}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ComboBoxBorderFocus}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#101828"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ItemHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ItemSelected}"/>
                                            <Setter Property="Foreground" Value="#101828"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <!-- ────── End of added resources ────── -->

    <Grid Background="{StaticResource ContentBgBrush}" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Heading + Export button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Weighment History" FontFamily="Segoe UI"
                           FontSize="26" FontWeight="Bold" Foreground="#1A1F3A"/>
                <TextBlock Text="View and manage all weighment records"
                           FontFamily="Segoe UI" FontSize="13" Foreground="#8A8E9B" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding ExportCsvCommand}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="↓ " FontSize="13"/>
                    <TextBlock Text="Export CSV" FontSize="13" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search & Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="⊟ " Foreground="#1A1F3A" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Search &amp; Filter" FontFamily="Segoe UI"
                               FontSize="14" FontWeight="SemiBold" Foreground="#1A1F3A"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Style="{StaticResource DPTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- ★ Modernised ComboBoxes ★ -->
                    <ComboBox Grid.Column="2" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="All Types" IsSelected="True"/>
                        <ComboBoxItem Content="Inbound"/>
                        <ComboBoxItem Content="Outbound"/>
                    </ComboBox>
                    <ComboBox Grid.Column="4" Style="{StaticResource ModernComboBoxStyle}">
                        <ComboBoxItem Content="All Status" IsSelected="True"/>
                        <ComboBoxItem Content="Completed"/>
                        <ComboBoxItem Content="Pending"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Records + DataGrid (unchanged) -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding FilteredRecords.Count, StringFormat='{}{0} Records Found'}"
                           FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1A1F3A" Margin="20,14,0,14"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          RowHeight="46"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          Background="White"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          SelectionMode="Single">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"  Value="#1A1F3A"/>
                            <Setter Property="Foreground"  Value="White"/>
                            <Setter Property="FontFamily"  Value="Segoe UI"/>
                            <Setter Property="FontSize"    Value="12"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="Padding"     Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize"   Value="13"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F5F7FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ticket #"   Binding="{Binding TicketNumber}"  Width="130"/>
                        <DataGridTextColumn Header="Date/Time"  Binding="{Binding DateTime, StringFormat='dd MMM yyyy, HH:mm'}" Width="160"/>
                        <DataGridTextColumn Header="Vehicle"    Binding="{Binding VehicleNumber}" Width="120"/>
                        <DataGridTextColumn Header="Driver"     Binding="{Binding DriverName}"    Width="140"/>
                        <DataGridTextColumn Header="Material"   Binding="{Binding Material}"      Width="160"/>
                        <DataGridTextColumn Header="Gross"      Binding="{Binding GrossWeight, StringFormat='{}{0:F2} MT'}" Width="90"/>
                        <DataGridTextColumn Header="Tare"       Binding="{Binding TareWeight,  StringFormat='{}{0:F2} MT'}" Width="90"/>
                        <DataGridTextColumn Header="Net"        Binding="{Binding NetWeight,   StringFormat='{}{0:F2} MT'}" Width="90"/>
                        <DataGridTextColumn Header="Type"       Binding="{Binding Type}"         Width="90"/>
                        <DataGridTextColumn Header="Status"     Binding="{Binding Status}"        Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>